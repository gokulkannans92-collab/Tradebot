# TradeBot Configuration Example
# Copy this file to .env and fill in your credentials

PYTHONIOENCODING=utf-8
BROKER_TYPE='angel'

# Zerodha Credentials
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Angel One Credentials
ANGEL_API_KEY=
ANGEL_API_SECRET=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# Upstox Credentials
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# Trading Parameters
TOTAL_CAPITAL=100000
TRADE_CAPITAL=100000
MAX_TRADES_PER_DAY=5
MAX_DAILY_LOSS=15000.0
TRADE_TARGET_RS=10000
TRADE_SL_RS=1000
USE_TSL=true
TSL_ACTIVATION_PERCENT=0.1
TSL_LOCK_PERCENT=0.1
MAX_RISK_PER_TRADE_PERCENT=2.0
PAPER_TRADING=true

# Strategy Settings
TRADING_SYMBOL_PREFIX=NIFTY
LOT_SIZE=65
NIFTY_STRIKE_STEP=50
NIFTY_OPTIONS_STRATEGY=true
BANKNIFTY_ENABLED=true
BANKNIFTY_LOT_SIZE=30
BANKNIFTY_STRIKE_STEP=100
STRATEGY=combined
MIN_SIGNALS_REQUIRED=3
CANDLE_PERIOD_SECONDS=300

# Monitoring & Logs
LOG_LEVEL=INFO
DEBUG_SIGNALS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Safety Limits
KILL_AFTER_DAILY_LIMIT=false
MAX_DAILY_LOSS_PCT=5
NIFTY_LOTS=1
BANKNIFTY_LOTS=1

# Razorpay (Optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin
ADMIN_REGISTRATION_KEY=

# Scheduling
SCHEDULE_ENABLED=true
SCHEDULE_START=09:20
SCHEDULE_STOP=15:00

# Security
ENCRYPTION_KEY=

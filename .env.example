# Broker Configuration (Zerodha)
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_ACCESS_TOKEN=your_access_token_here

# Broker Configuration (Angel One)
ANGEL_API_KEY=your_api_key_here
ANGEL_API_SECRET=your_api_secret_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# Broker Configuration (Upstox)
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here

# Trading Settings
TOTAL_CAPITAL=100000
TRADE_CAPITAL=100000.0
MAX_TRADES_PER_DAY=5
MAX_DAILY_LOSS=15000.0
TRADE_TARGET_RS=25000.0
TRADE_SL_RS=1000.0
USE_TSL=true
TSL_ACTIVATION_PERCENT=0.5
TSL_LOCK_PERCENT=0.1
MAX_RISK_PER_TRADE_PERCENT=2.0
PAPER_TRADING=true

# Symbol Settings
TRADING_SYMBOL_PREFIX=NIFTY
LOT_SIZE=65
NIFTY_STRIKE_STEP=50
NIFTY_OPTIONS_STRATEGY=true
BANKNIFTY_ENABLED=true
BANKNIFTY_LOT_SIZE=30
BANKNIFTY_STRIKE_STEP=100

# Strategy Settings
STRATEGY=combined
MIN_SIGNALS_REQUIRED=2
CANDLE_PERIOD_SECONDS=300
LOG_LEVEL=INFO
DEBUG_SIGNALS=false

# Notification Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Payment Settings (Optional)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Admin Settings
ADMIN_REGISTRATION_KEY=your_registration_key_here

# Schedule Settings
SCHEDULE_ENABLED=true
SCHEDULE_START=09:00
SCHEDULE_STOP=02:30

# Kill Switch
KILL_AFTER_DAILY_LIMIT=false
MAX_DAILY_LOSS_PCT=5.0
NIFTY_LOTS=2
BANKNIFTY_LOTS=1

# ── Broker API Credentials ────────────────────────────────────────────
# Add your actual credentials to .env (DO NOT COMMIT)
# Never share these keys with anyone

# Zerodha Kiteconnect
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token_here

# Angel One
ANGEL_ONE_API_KEY=your_angel_one_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_angel_one_password_here
ANGEL_ONE_TOTP_KEY=your_totp_secret_key_here

# Upstox
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# ── Database Configuration ────────────────────────────────────────────
DATABASE_URL=sqlite:///./trades.db

# ── Application Settings ────────────────────────────────────────────
DEBUG=False
LOG_LEVEL=INFO
MAX_DAILY_LOSS_LIMIT=5000
TRAILING_STOP_LEVELS=6

# ── Server Configuration ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secret_key_for_jwt_here
